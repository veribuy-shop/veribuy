# Next.js Environment Variables
# Copy this file to .env.local and fill in your actual values

# ─── Server Configuration ─────────────────────────────────
PORT=3010

# ─── Frontend Public Variables (exposed to browser) ─────────
# These variables are embedded in the client-side JavaScript bundle
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VeriBuy

# Stripe Publishable Key (Safe to expose in browser)
# Get your test key from: https://dashboard.stripe.com/test/apikeys
# Format: pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe Secret Key (SERVER-SIDE ONLY - Never expose to browser)
# Get your test key from: https://dashboard.stripe.com/test/apikeys
# Format: sk_test_...
# Used for webhook signature verification
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Stripe Webhook Secret (SERVER-SIDE ONLY)
# Get this from: https://dashboard.stripe.com/test/webhooks
# Format: whsec_...
# Used to verify webhook requests are from Stripe
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ─── Internal Service URLs (server-side only) ───────────────
# These are used by Next.js API routes to communicate with backend microservices
# For local development: Use localhost
# For Docker: Use service names (auth-service, user-service, etc.)

AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
LISTING_SERVICE_URL=http://localhost:3003
TRUST_LENS_SERVICE_URL=http://localhost:3004
EVIDENCE_SERVICE_URL=http://localhost:3006
TRANSACTION_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008

# ─── Notes ─────────────────────────────────────────────────
# 1. Never commit .env.local to version control
# 2. Use test keys for development (pk_test_... and sk_test_...)
# 3. For production, use live keys (pk_live_... and sk_live_...)
# 4. The NEXT_PUBLIC_ prefix makes variables available in the browser
# 5. Variables without this prefix are only available server-side
