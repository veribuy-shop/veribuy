generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/transaction-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["transactions"]
}

model Order {
  id               String      @id @default(uuid())
  buyerId          String      @map("buyer_id")
  sellerId         String      @map("seller_id")
  listingId          String      @map("listing_id")
  listingTitle       String?     @map("listing_title")
  listingDescription String?     @map("listing_description")
  listingCategory    String?     @map("listing_category")
  amount             Decimal     @db.Decimal(10, 2)
  currency           String      @default("GBP")
  status           OrderStatus @default(PENDING)
  escrowId         String?     @map("escrow_id")
  paymentIntentId  String?     @map("payment_intent_id")
  trackingNumber   String?     @map("tracking_number")
  shippingAddress  Json?       @map("shipping_address")
  paidAt           DateTime?   @map("paid_at")
  shippedAt        DateTime?   @map("shipped_at")
  deliveredAt      DateTime?   @map("delivered_at")
  completedAt      DateTime?   @map("completed_at")
  disputedAt       DateTime?   @map("disputed_at")
  refundedAt       DateTime?   @map("refunded_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
  @@index([paymentIntentId])
  @@index([createdAt])
  @@index([buyerId, status])
  @@index([sellerId, status])
  @@schema("transactions")
  @@map("orders")
}

model EscrowRecord {
  id            String       @id @default(uuid())
  orderId       String       @unique @map("order_id")
  amount        Decimal      @db.Decimal(10, 2)
  currency      String       @default("GBP")
  status        EscrowStatus @default(HELD)
  providerRef   String?      @map("provider_ref")
  heldAt        DateTime     @default(now()) @map("held_at")
  releasedAt    DateTime?    @map("released_at")
  refundedAt    DateTime?    @map("refunded_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@schema("transactions")
  @@map("escrow_records")
}

enum OrderStatus {
  PENDING
  PAYMENT_RECEIVED
  ESCROW_HELD
  SHIPPED
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
  CANCELLED

  @@schema("transactions")
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED

  @@schema("transactions")
}

model Invoice {
  id            String        @id @default(uuid())
  orderId       String        @map("order_id")
  invoiceNumber String        @unique @map("invoice_number")
  status        OrderStatus   @map("status")
  buyerId       String        @map("buyer_id")
  sellerId      String        @map("seller_id")
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("GBP")
  pdfUrl        String?       @map("pdf_url")
  emailSentAt   DateTime?     @map("email_sent_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([createdAt])
  @@schema("transactions")
  @@map("invoices")
}
