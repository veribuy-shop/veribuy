# Transaction Service Environment Variables
# Copy this file to .env and fill in your actual values

# ─── Database Configuration ─────────────────────────────────
# PostgreSQL connection string for the transactions schema
DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=transactions
TRANSACTION_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=transactions

# ─── Stripe Configuration ───────────────────────────────────
# IMPORTANT: Never commit real keys to version control!
# Get your keys from: https://dashboard.stripe.com/test/apikeys

# Stripe Secret Key (KEEP THIS SECRET!)
# For development: Use test key (starts with sk_test_...)
# For production: Use live key (starts with sk_live_...)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Optional: Stripe Publishable Key (for reference, mainly used in frontend)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# ─── Service Configuration ──────────────────────────────────
PORT=3007

# ─── Observability ──────────────────────────────────────────
# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Notes ─────────────────────────────────────────────────
# 1. NEVER commit .env file with real keys to Git
# 2. Add .env to .gitignore (already done)
# 3. Use different keys for development/staging/production
# 4. Test keys are safe to use in development
# 5. Rotate keys immediately if accidentally exposed
# 6. For production, use secrets management (AWS Secrets Manager, Vault, etc.)
