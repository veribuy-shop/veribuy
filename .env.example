# VeriBuy Environment Configuration
# Copy this file to .env and fill in the values

# ─── Database ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=veribuy
POSTGRES_PASSWORD=veribuy_dev_password
POSTGRES_DB=veribuy

# Per-service database URLs (using schemas)
# For Docker: Use @postgres:5432
# For Local:  Use @localhost:5432
# PRODUCTION: Must append ?sslmode=require (or &sslmode=require) to every URL.
#             Also set DIRECT_DATABASE_URL to the same value — used by Prisma
#             for migrations and direct queries that bypass a connection pooler.
#             Railway Postgres: copy the "Postgres Connection URL" value from
#             the Railway dashboard and append ?sslmode=require.
AUTH_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=auth
USER_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=users
LISTING_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=listings
TRUST_LENS_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=trust_lens
EVIDENCE_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=evidence
TRANSACTION_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=transactions
NOTIFICATION_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=notifications

# Direct DB URL (same value as DATABASE_URL for each service — required by Prisma
# when a connection pooler is in use; also used as the sslmode=require-enforced URL)
# PRODUCTION: DIRECT_DATABASE_URL=postgresql://...?schema=<name>&sslmode=require
DIRECT_DATABASE_URL=postgresql://veribuy:veribuy_dev_password@localhost:5432/veribuy?schema=auth

# ─── Redis ──────────────────────────────────────────────────
# For Docker: Use redis
# For Local:  Use localhost
# PRODUCTION: Set REDIS_TLS=true and ensure REDIS_PORT=6380 (Railway TLS port).
#             If Railway injects REDIS_URL, also set REDIS_TLS=true — the service
#             will automatically promote redis:// to rediss://.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=veribuy_redis_dev
REDIS_TLS=false

# ─── RabbitMQ ───────────────────────────────────────────────
# For Docker: Use rabbitmq
# For Local: Use localhost
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=veribuy
RABBITMQ_PASSWORD=veribuy_rabbit_dev
RABBITMQ_URL=amqp://veribuy:veribuy_rabbit_dev@localhost:5672

# ─── MinIO (S3-compatible storage) ──────────────────────────
# For Docker: Use minio
# For Local: Use localhost
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=veribuy_minio
MINIO_SECRET_KEY=veribuy_minio_secret
MINIO_BUCKET=veribuy-evidence

# ─── JWT / Auth ─────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ─── Service Ports ──────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
LISTING_SERVICE_PORT=3003
TRUST_LENS_SERVICE_PORT=3004
DEVICE_VERIFICATION_SERVICE_PORT=3005
EVIDENCE_SERVICE_PORT=3006
TRANSACTION_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008

# ─── External APIs ──────────────────────────────────────────
IMEI_CHECK_API_KEY=your-imeicheck-api-key
IMEI_CHECK_API_URL=https://api.imeicheck.com
IFREE_ICLOUD_API_KEY=your-ifreeicloud-api-key
IFREE_ICLOUD_API_URL=https://ifreeicloud.co.uk

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VeriBuy

# ─── Internal Service URLs (for Next.js API proxies and inter-service calls) ─
# For Docker: Use service names (auth-service, user-service, etc.)
# For Local:  Use localhost
# PRODUCTION: Must use https:// — the gateway and all services enforce this at
#             startup (process.exit(1) if any URL is http:// in NODE_ENV=production).
#             On Railway, set these to the private internal Railway URLs, e.g.:
#               AUTH_SERVICE_URL=https://auth-service.railway.internal
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
LISTING_SERVICE_URL=http://localhost:3003
TRUST_LENS_SERVICE_URL=http://localhost:3004
DEVICE_VERIFICATION_SERVICE_URL=http://localhost:3005
EVIDENCE_SERVICE_URL=http://localhost:3006
