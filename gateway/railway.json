{
  "$schema": "https://schema.railway.app/railway.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "gateway/Dockerfile",
    "watchPatterns": [
      "gateway/**/*",
      "packages/**/*"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
